# Copy to terraform.tfvars (gitignored) or rely on TF_VAR_* env from .env.
project         = "swa-demo"
aws_region      = "us-east-1"
rhel_version    = "9"
instance_type   = "m5.xlarge"
root_volume_gb  = 60

# Lock these down for anything beyond a throwaway demo:
admin_cidrs     = ["0.0.0.0/0"] # set to YOUR.IP/32 (add more for other locations)
key_pair_name   = ""            # empty => Terraform generates swa-demo-key.pem
webapp_nodeport = 30080

# Optional HTTPS via ALB (ACM-managed, DNS-validated, auto-renewing):
# domain_name     = "swa.pineappledev.app" # add acm_validation_records at your DNS host; CNAME this at alb_dns_name
# certificate_arn = ""                      # optional override: a pre-imported cert ARN instead of ACM-managed
