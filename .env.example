# =============================================================================
# swa-demo configuration.  Copy to .env and fill in.  NEVER commit the real .env.
#   cp .env.example .env
# All values are consumed by the Makefile and passed to Terraform/Ansible/Helm.
# =============================================================================

# --- AWS / Terraform -------------------------------------------------------
export AWS_REGION="us-east-1"
export AWS_PROFILE="default"
# Name of an existing EC2 key pair, OR leave blank to let Terraform create one.
export TF_VAR_key_pair_name=""
# Your public IP (CIDR) allowed to SSH / reach the NodePort. Find with: curl ifconfig.me
export TF_VAR_admin_cidr="0.0.0.0/0"
# RHEL major version for the AMI lookup: 8 or 9
export TF_VAR_rhel_version="9"
export TF_VAR_instance_type="m5.xlarge"
export TF_VAR_root_volume_gb="60"
export TF_VAR_project="swa-demo"

# --- CyberArk Secrets Manager - SaaS (Idira) / Conjur Cloud tenant ---------
# Control-plane URL the SWA server talks to (Conjur Cloud), e.g.
# https://<subdomain>.secretsmgr.cyberark.cloud
export SWA_CONTROLPLANE_URL=""
# Tenant config is done by terraform-swa (cyberark/swa provider) using your
# `conjur login` session — no token needed for the primary path.
export SWA_TRUST_DOMAIN="swa-demo.example.com"
export SWA_SERVER_GROUP="minikube-servers"
export SWA_NODE_GROUP="minikube-nodes"
export SWA_CLUSTER_NAME="minikube"
export SWA_SERVER_NAME="minikube-server-1"
# Optional control-plane bootstrap token.json for the server (--set-file). Leave
# empty unless your tenant requires it.
export SWA_CONTROLPLANE_TOKEN_FILE=""

# Path to the unpacked SWA release bundle (provider installer + charts + images).
export SWA_RELEASE_DIR="$HOME/Downloads/Secure Workload Access/Secure Workload Access/swa-release-v1.0.0"

# authn_id is produced by terraform-swa apply (swa_server.authn_id) and bridged
# to the host automatically; set here only to override.
export SWA_AUTHN_ID=""

# --- REST fallback only (tenant/*.sh) --------------------------------------
# Used solely if you run the REST scripts instead of terraform-swa.
export SWA_TENANT_URL=""
export SWA_TENANT_API_TOKEN=""

# --- SWA images (delivered as arch-specific *.tar, hosted in YOUR S3 bucket) -
# No registry: the EC2 host (via its IAM instance profile) reads this S3 prefix,
# Ansible loads every *-amd64.tar into minikube, auto-detecting each repo:tag.
# Upload the bundle's container-images/*.tar to this prefix.
export SWA_IMAGES_S3_URI="s3://your-bucket/swa-images"
# Grant the host read access to that bucket/prefix (used by Terraform IAM):
export TF_VAR_images_s3_uri="${SWA_IMAGES_S3_URI}"
# Optional: override auto-detection if server/agent can't be told apart by name.
# export SWA_SERVER_IMAGE="repo/swa-server:1.2.3"
# export SWA_AGENT_IMAGE="repo/swa-agent:1.2.3"

# SWA Helm charts come from the release bundle. `make vendor-charts` copies
# helm/swa-*.tgz into helm/charts/ (synced to the host and used automatically).
# Override with explicit refs only if needed:
# export SWA_SERVER_CHART="oci://<registry>/charts/swa-server"
# export SWA_AGENT_CHART="oci://<registry>/charts/swa-agent"

# --- Kubernetes namespaces -------------------------------------------------
export NS_SWA="swa-system"
export NS_DEMO="swa-demo"

# --- Demo webapp -----------------------------------------------------------
export WEBAPP_IMAGE="swa-demo-webapp:dev"
export WEBAPP_JWT_AUDIENCE="swa-demo-audience"
export WEBAPP_NODEPORT="30080"
