# =============================================================================
# swa-demo configuration.  Copy to .env and fill in.  NEVER commit the real .env.
#   cp .env.example .env
# All values are consumed by the Makefile and passed to Terraform/Ansible/Helm.
# =============================================================================

# --- AWS / Terraform -------------------------------------------------------
export AWS_REGION="us-east-1"
export AWS_PROFILE="default"
# Name of an existing EC2 key pair, OR leave blank to let Terraform create one.
export TF_VAR_key_pair_name=""
# Your public IP (CIDR) allowed to SSH / reach the NodePort. Find with: curl ifconfig.me
export TF_VAR_admin_cidr="0.0.0.0/0"
# RHEL major version for the AMI lookup: 8 or 9
export TF_VAR_rhel_version="9"
export TF_VAR_instance_type="m5.xlarge"
export TF_VAR_root_volume_gb="60"
export TF_VAR_project="swa-demo"

# --- CyberArk Secrets Manager - SaaS (Idira) tenant ------------------------
# Base URL of your tenant, e.g. https://<subdomain>.secretsmgr.cyberark.cloud
export SWA_TENANT_URL=""
# API token / bearer used by tenant/*.sh to create trust domain, groups, register server.
export SWA_TENANT_API_TOKEN=""
export SWA_TRUST_DOMAIN="swa-demo.example.com"
export SWA_SERVER_GROUP="minikube-servers"
export SWA_NODE_GROUP="minikube-nodes"

# Populated by tenant/03-register-server.sh after server registration.
export SWA_AUTHN_ID=""

# --- SWA container images (Palo Alto Networks Marketplace entitlement) ------
export SWA_IMAGE_REGISTRY=""        # e.g. registry.cyberark.cloud/swa
export SWA_SERVER_IMAGE_TAG="latest"
export SWA_AGENT_IMAGE_TAG="latest"
# Registry pull credentials -> become a k8s imagePullSecret
export SWA_REGISTRY_USERNAME=""
export SWA_REGISTRY_PASSWORD=""

# SWA Helm chart coordinates. Defaults assume charts are published under the same
# registry (OCI). Override if your entitlement publishes them elsewhere.
# export SWA_HELM_REPO="oci://${SWA_IMAGE_REGISTRY}/charts"
# export SWA_SERVER_CHART="${SWA_HELM_REPO}/swa-server"
# export SWA_AGENT_CHART="${SWA_HELM_REPO}/swa-agent"
export SWA_SERVER_NAME="minikube-server-1"

# --- Kubernetes namespaces -------------------------------------------------
export NS_SWA="cyberark-swa"
export NS_DEMO="swa-demo"

# --- Demo webapp -----------------------------------------------------------
export WEBAPP_IMAGE="swa-demo-webapp:dev"
export WEBAPP_JWT_AUDIENCE="swa-demo-audience"
export WEBAPP_NODEPORT="30080"
